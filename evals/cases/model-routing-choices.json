[
  {
    "id": "model-routing-chat-prefers-local-chat",
    "suite": "model_routing_choices",
    "mode": "deterministic",
    "task": "Route normal chat to the enabled local chat model.",
    "input": {
      "use_case": "chat",
      "models": [
        {
          "id": "ollama:chat",
          "provider": "ollama",
          "capabilities": ["chat", "long-context", "local-only"],
          "enabled": true,
          "privacyLevel": "local-only",
          "requiresNetwork": false
        },
        {
          "id": "automatic1111:image-generation",
          "provider": "automatic1111",
          "capabilities": ["image-generation", "local-only"],
          "enabled": true,
          "privacyLevel": "local-only",
          "requiresNetwork": false
        }
      ]
    },
    "deterministic_expectations": {
      "expected_status": "selected",
      "expected_model_id": "ollama:chat",
      "expected_local_only": true,
      "expected_requires_network": false
    }
  },
