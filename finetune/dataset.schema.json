{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.jarvis/finetune/conversation.schema.json",
  "title": "Jarvis fine-tuning conversation record",
  "description": "One cleaned chat-style training record. prepare_data.py additionally enforces assistant-last targets and assistant-not-first records.",
  "type": "object",
  "additionalProperties": false,
  "required": ["messages"],
  "properties": {
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "quality": {
      "type": "string",
      "enum": ["gold", "silver", "draft"]
    },
    "notes": {
      "type": "string"
    }
  }
}
